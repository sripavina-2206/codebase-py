def caesar_cipher(text, shift, mode='encode'):
    result = ""
    if mode == 'decode':
        shift = -shift
        
    for char in text:
        if char.isalpha():
            # Shift characters while staying within alphabet bounds
            start = ord('a') if char.islower() else ord('A')
            new_char = chr(start + (ord(char) - start + shift) % 26)
            result += new_char
        else:
            result += char # Keep numbers and spaces as they are
    return result

if __name__ == "__main__":
    msg = input("Enter message: ")
    s = int(input("Enter shift value (1-25): "))
    
    encoded = caesar_cipher(msg, s, 'encode')
    print("\nEncrypted: {}".format(encoded))
    print("Decrypted: {}".format(caesar_cipher(encoded, s, 'decode')))

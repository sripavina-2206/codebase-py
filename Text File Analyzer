def analyze_file(filename):
    try:
        with open(filename, 'r') as file:
            content = file.read()
            words = content.split()
            unique_words = set(words)
            
            print("\n--- File Stats: {} ---".format(filename))
            print("Total Words:     {}".format(len(words)))
            print("Unique Words:    {}".format(len(unique_words)))
            print("Character Count: {}".format(len(content)))
    except FileNotFoundError:
        print("Error: The file '{}' was not found.".format(filename))

if __name__ == "__main__":
    # Create a test file first if it doesn't exist
    test_file = "sample.txt"
    with open(test_file, "w") as f:
        f.write("Hello world! Python is a great application language for GitHub.")
        
    analyze_file(test_file)
